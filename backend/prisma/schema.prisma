generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id      String  @id @default(uuid())
  name    String
  users   User[]
  stores  Store[]
}

model User {
  id        String @id @default(uuid())
  username  String
  password  String
  role      String @default("user")
  tenantId  String?
  tenant    Tenant? @relation(fields: [tenantId], references: [id])
}

model Store {
  id         String @id @default(uuid())
  name       String
  city       String
  manager    String
  status     String
  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id])
  sales      Sale[]
  targets    SalesTarget[]
}

model Sale {
  id        String   @id @default(uuid())
  storeId   String
  date      DateTime
  revenue   Float
  orders    Int
  avgTicket Float
  store     Store @relation(fields: [storeId], references: [id])
}

model SalesTarget {
  id        String   @id @default(uuid())
  storeId   String
  year      Int
  month     Int
  target    Float
  store     Store @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([storeId, year, month])
}

model LlmLog {
  id        String   @id @default(uuid())
  type      String
  input     String
  output    String
  model     String
  duration  Int
  tenantId  String?
  createdAt DateTime @default(now())
}

model McpLog {
  id        String   @id @default(uuid())
  tool      String
  params    String
  result    String
  storeId   String?
  tenantId  String?
  createdAt DateTime @default(now())
}
